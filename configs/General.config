# =====分区核心=====
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_PERSISTENT=y
CONFIG_SQUASHFS_XZ=y
# CONFIG_SQUASHFS_LZ4 is not set
CONFIG_TARGET_ROOTFS_OVERLAY=y
CONFIG_FS_OVERLAYFS=y
CONFIG_TARGET_ROOTFS_UBIFS=y
CONFIG_TARGET_UBIFS_FS=y
CONFIG_TARGET_ROOTFS_SYSUPGRADE=y
CONFIG_TARGET_ROOTFS_FACTORY=y
CONFIG_CCACHE=y
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
# CONFIG_TARGET_PER_DEVICE_ROOTFS is not set
# CONFIG_FEED_nss_packages is not set
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set

# =====6.12 内核调度=====
CONFIG_KERNEL_PREEMPT=y
# CONFIG_KERNEL_PREEMPT_RT is not set
CONFIG_KERNEL_HZ=250
CONFIG_KERNEL_CGROUP_SCHED=y
CONFIG_KERNEL_FAIR_GROUP_SCHED=y
CONFIG_KERNEL_SCHED_AUTOGROUP=y

# =====6.12 内存=====
CONFIG_KERNEL_ZRAM=y
CONFIG_KERNEL_ZRAM_BACKEND_LZ4=y
CONFIG_KERNEL_ZRAM_DEF_COMP_LZ4=y
CONFIG_KERNEL_ZRAM_BACKEND_ZSTD=y
# CONFIG_KERNEL_ZRAM_BACKEND_LZO is not set
CONFIG_KERNEL_SWAP=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lz4=y
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=y
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE_ALWAYS=y

# =====6.12 TCP BBRv3=====
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"

# =====6.12 网络多队列=====
CONFIG_KERNEL_RPS=y
CONFIG_KERNEL_XPS=y
CONFIG_KERNEL_RFS_ACCEL=y
CONFIG_KERNEL_NET_SCH_MULTIQ=y

# =====6.12 硬件加速=====
CONFIG_KERNEL_CRC32_SLICEBY8=y
CONFIG_KERNEL_CRC32_SARWATE=y
CONFIG_KERNEL_IRQ_AFFINITY=y

#基础工具
CONFIG_PACKAGE_tmux=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano-full=y
CONFIG_PACKAGE_zoneinfo-asia=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_autocore=y

#Zerotier+防火墙
CONFIG_PACKAGE_zerotier=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-app-firewall=y

#CPU调频
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-i18n-cpufreq-zh-cn=y

#NSS全套
CONFIG_PACKAGE_kmod-qca-nss-drv-igs=y
CONFIG_PACKAGE_kmod-qca-nss-drv-lag-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-map-t=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-nat=y
CONFIG_NSS_DRV_SHAPER_ENABLE=y
CONFIG_NSS_DRV_PVXLAN_ENABLE=y
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-ssdk=y
CONFIG_PACKAGE_qca-nss-fw-ipq60xx=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_NSS_ECM_SWITCH_ENABLE=y
CONFIG_PACKAGE_kmod-qca-nss-drv-tcp=y
CONFIG_PACKAGE_kmod-qca-nss-drv-udp=y
CONFIG_PACKAGE_kmod-qca-nss-drv-flow=y
CONFIG_PACKAGE_kmod-qca-nss-drv-fullcone=y
# CONFIG_PACKAGE_kmod-qca-nss-ecm-nat is not set
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe-tap=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe-relay=y
CONFIG_PACKAGE_kmod-qca-nss-drv-tun=y
CONFIG_PACKAGE_kmod-qca-nss-drv-gre=y
CONFIG_PACKAGE_kmod-qca-nss-drv-ipsec=y
CONFIG_PACKAGE_kmod-qca-nss-drv-udp-lite=y
CONFIG_PACKAGE_kmod-qca-nss-drv-vlan=y
CONFIG_PACKAGE_kmod-qca-nss-drv-policer=y
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y
# CONFIG_PACKAGE_kmod-qca-nss-drv-cake is not set
CONFIG_PACKAGE_kmod-qca-nss-drv-flow-preload=y
CONFIG_NSS_DRV_FLOW_PRELOAD_ENABLE=y
CONFIG_NSS_DRV_FLOW_CACHE=y
CONFIG_NSS_ECM_PRELOAD_CONN=y
CONFIG_NSS_ECM_FLOW_CACHE=y
CONFIG_PACKAGE_kmod-qca-nss-drv-reassemble=y
CONFIG_NSS_DRV_REASSEMBLE_ENABLE=y
CONFIG_PACKAGE_nssinfo=y
CONFIG_PACKAGE_nssstats=y
CONFIG_PACKAGE_luci-app-nssinfo=y
CONFIG_PACKAGE_luci-i18n-nssinfo-zh-cn=y
# CONFIG_PACKAGE_kmod-qca-nss-drv-wifi is not set
# CONFIG_PACKAGE_kmod-qca-nss-ppe is not set

#PPPoE
CONFIG_PACKAGE_kmod-ppp=y
CONFIG_PACKAGE_kmod-pppoe=y
CONFIG_PACKAGE_kmod-pppox=y
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y

#多核+转发
CONFIG_PACKAGE_irqbalance=y
CONFIG_KERNEL_NF_CONNTRACK=y
CONFIG_PACKAGE_kmod-mq=y
CONFIG_KERNEL_NF_FLOW_OFFLOAD=y
CONFIG_PACKAGE_kmod-nft-flow=y
CONFIG_KERNEL_NF_CONNTRACK_MARK=y
CONFIG_KERNEL_NF_CONNTRACK_ZONES=y
CONFIG_KERNEL_NF_CONNTRACK_EARLY_OFFLOAD=y
CONFIG_PACKAGE_kmod-sched-fq_codel=y
CONFIG_PACKAGE_kmod-sched-core=y
# CONFIG_PACKAGE_kmod-sched-cake is not set

#DNS
CONFIG_PACKAGE_dnsmasq-full=y

#WiFi AX5
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-pci=y
CONFIG_PACKAGE_ath11k-firmware-ipq6018=y
CONFIG_PACKAGE_ipq-wifi-xiaomi_redmi_ax5=y
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_hostapd=y
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_DEFAULT_WIFI_REGDOM="US"

#NFTables
CONFIG_PACKAGE_kmod-nf-nat6=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-netdev=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_ttyd=y

#双主题+汉化
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-aurora=y
CONFIG_PACKAGE_luci-app-aurora-config=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

#常驻插件
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_luci-app-frpc=y
CONFIG_PACKAGE_luci-app-frps=y
CONFIG_PACKAGE_luci-app-watchcat=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_luci-app-oaf=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-app-athena-led=y
CONFIG_PACKAGE_libminiupnpc=y
CONFIG_PACKAGE_miniupnpd-nftables=y

