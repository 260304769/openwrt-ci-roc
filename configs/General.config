# Rootfs 镜像生成(必开sysupgrade/factory/bin/ubi)
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_PERSISTENT=y
CONFIG_SQUASHFS_XZ=y
# CONFIG_SQUASHFS_LZ4 is not set
CONFIG_TARGET_ROOTFS_OVERLAY=y
CONFIG_FS_OVERLAYFS=y
CONFIG_TARGET_ROOTFS_UBIFS=y
CONFIG_TARGET_UBIFS_FS=y
CONFIG_TARGET_ROOTFS_SYSUPGRADE=y
CONFIG_TARGET_ROOTFS_FACTORY=y

CONFIG_CCACHE=y
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
# CONFIG_LUCI_LANG_zh_Hant is not set

# CONFIG_FEED_video is not set
# CONFIG_FEED_nss_packages is not set
# CONFIG_FEED_sqm_scripts_nss is not set
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set

# ZRAM Swap
CONFIG_KERNEL_ZRAM=y
CONFIG_KERNEL_SWAP=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lz4=y
CONFIG_KERNEL_ZRAM_BACKEND_LZ4=y
# CONFIG_KERNEL_ZRAM_BACKEND_LZO is not set
CONFIG_KERNEL_ZRAM_DEF_COMP_LZ4=y

# Base tools
CONFIG_PACKAGE_tmux=y
CONFIG_PACKAGE_dmesg=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_btop=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_tune2fs=y
CONFIG_PACKAGE_zerotier=y
CONFIG_PACKAGE_fstrim=y
CONFIG_PACKAGE_nano-full=y
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_coremark=y
CONFIG_PACKAGE_hdparm=y
CONFIG_PACKAGE_smartmontools-drivedb=y
CONFIG_PACKAGE_zoneinfo-core=y
# CONFIG_PACKAGE_zoneinfo-asia is not set
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_acme-acmesh-dnsapi=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
CONFIG_PACKAGE_openssh-sftp-server=y
# CONFIG_PACKAGE_sqm-scripts-nss is not set
CONFIG_PACKAGE_luci-app-firewall=y

# NSS硬件加速全套配置
# CONFIG_PACKAGE_kmod-qca-nss-drv-wifi is not set
CONFIG_PACKAGE_kmod-qca-nss-drv-igs=y
# CONFIG_PACKAGE_kmod-qca-nss-drv-l2tpv2 is not set
CONFIG_PACKAGE_kmod-qca-nss-drv-lag-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-map-t=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
# CONFIG_PACKAGE_kmod-qca-nss-drv-pptp is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc is not set
CONFIG_PACKAGE_kmod-qca-nss-drv-nat=y
# CONFIG_PACKAGE_kmod-qca-nss-macsec is not set
CONFIG_NSS_DRV_SHAPER_ENABLE=y
CONFIG_NSS_DRV_PVXLAN_ENABLE=y
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-ssdk=y
CONFIG_PACKAGE_qca-nss-fw-ipq60xx=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_NSS_ECM_SWITCH_ENABLE=y
CONFIG_PACKAGE_kmod-qca-nss-drv-tcp=y
CONFIG_PACKAGE_kmod-qca-nss-drv-udp=y
CONFIG_PACKAGE_kmod-qca-nss-drv-flow=y

# CPU多核优化 RPS/XPS/软中断均衡
CONFIG_KERNEL_RPS=y
CONFIG_KERNEL_XPS=y
CONFIG_PACKAGE_irqbalance=y

# 内核连接跟踪
CONFIG_KERNEL_NF_CONNTRACK=y

# QoS FQ_CODEL
CONFIG_PACKAGE_kmod-sched-fq_codel=y
CONFIG_PACKAGE_kmod-sched-core=y
# CONFIG_PACKAGE_kmod-sched-cake is not set

# DNS dnsmasq完整功能
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsforwarder is not set

# ath11k无线驱动 IPQ6018标配
# CONFIG_PACKAGE_kmod-mac80211 is not set
CONFIG_PACKAGE_kmod-ath11k=y
# CONFIG_PACKAGE_kmod-ath11k-ahb is not set
CONFIG_PACKAGE_kmod-ath11k-pci=y
CONFIG_PACKAGE_ath11k-firmware-ipq6018=y
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_hostapd=y
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-qrtr=y

# nftables全套内核模块
CONFIG_PACKAGE_kmod-nf-nat6=y
CONFIG_PACKAGE_kmod-nft-arp=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-nft-connlimit=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-dup-inet=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-netdev=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-queue=y
CONFIG_PACKAGE_kmod-nft-socket=y
# CONFIG_PACKAGE_kmod-nft-tproxy is not set
CONFIG_PACKAGE_kmod-nft-xfrm=y
CONFIG_PACKAGE_kmod-nft-state=y
CONFIG_PACKAGE_ttyd=y

# 内核性能优化
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=y
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE_ALWAYS=y
# CONFIG_KERNEL_HUGETLBFS is not set
# CONFIG_KERNEL_HUGETLB_PAGE is not set
CONFIG_KERNEL_NET_CLS_CGROUP=y
CONFIG_KERNEL_NETWORK_SECMARK=y
CONFIG_KERNEL_NETFILTER_NETLINK=y
CONFIG_KERNEL_IRQ_AFFINITY=y

# Web主题
# CONFIG_PACKAGE_luci-theme-aurora is not set
# CONFIG_PACKAGE_luci-app-aurora-config is not set
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# Luci常用插件
# CONFIG_PACKAGE_luci-app-acme is not set
# CONFIG_PACKAGE_luci-app-ddns is not set
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wol=y
# CONFIG_PACKAGE_luci-app-samba4 is not set
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE-luci-app-autoreboot=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
# CONFIG_PACKAGE_luci-app-frps is not set
# CONFIG_PACKAGE_luci-app-frpc is not set
# CONFIG_PACKAGE-luci-app-diskman is not set
# CONFIG_PACKAGE-luci-app-hd-idle is not set
# CONFIG_PACKAGE-luci-app-3cat is not set
CONFIG_PACKAGE_luci-app-watchcat=y
# CONFIG_PACKAGE-luci-proto-wireguard is not set
# CONFIG_PACKAGE-luci-app-nlbwmon is not set
CONFIG_PACKAGE_curl=y
# CONFIG_PACKAGE-luci-app-banip is not set
# CONFIG_PACKAGE-luci-app-arpbind is not set
# CONFIG_PACKAGE-luci-app-usb-printer is not set
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE-luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_libminiupnpc=y
CONFIG_PACKAGE_miniupnpd-nftables=y
CONFIG_PACKAGE_luci-app-oaf=y
# CONFIG_PACKAGE-luci-app-sqm is not set
CONFIG_PACKAGE_luci-app-ttyd=y
# CONFIG_PACKAGE-luci-app-wechatpush is not set
# CONFIG_PACKAGE-luci-app-smartdns is not set
# CONFIG_PACKAGE-luci-app-lucky is not set
# CONFIG_PACKAGE-luci-app-openclash is not set
# CONFIG_PACKAGE-luci-app-passwall2 is not set
# CONFIG_PACKAGE-luci-app-wifischedule is not set

# Passwall源码预留(不默认编译)
# CONFIG_PACKAGE_luci-app-passwall is not set
