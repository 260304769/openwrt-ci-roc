### 通用配置文件 ###
CONFIG_CCACHE=y
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_LUCI_LANG_zh_Hant=y

CONFIG_FEED_video=n
CONFIG_FEED_nss_packages=n
CONFIG_FEED_sqm_scripts_nss=n
CONFIG_TARGET_ROOTFS_INITRAMFS=n

# ZRAM 内存压缩（AX5 256M内存刚需）
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lz4=y
CONFIG_KERNEL_ZRAM_BACKEND_LZ4=y
CONFIG_KERNEL_ZRAM_BACKEND_LZO=y
CONFIG_KERNEL_ZRAM_DEF_COMP_LZ4=y

# 网络协议/虚拟网口/网络诊断
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-dummy=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-netlink-diag=y
CONFIG_PACKAGE_kmod-veth=y

# TCP 拥塞控制 BBR + CUBIC
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_DEFAULT_TCP_CONG_BBR=y
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_CONG_CUBIC=y

# 网络基础工具 + 测速工具
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iperf3=y

# 基础运维工具（精简冗余）
CONFIG_PACKAGE_tmux=y
CONFIG_PACKAGE_dmesg=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_btop=n
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_sgdisk=n
CONFIG_PACKAGE_tune2fs=n
CONFIG_PACKAGE_zerotier=y

CONFIG_PACKAGE_fstrim=y
CONFIG_PACKAGE_nano-full=y
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_coremark=n
CONFIG_PACKAGE_hdparm=n
CONFIG_PACKAGE_smartmontools-drivedb=n
CONFIG_PACKAGE_zoneinfo-asia=y

# 服务、证书、DDNS、SFTP
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_acme-acmesh-dnsapi=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_sqm-scripts-nss=n

# ==============================
# NSS 硬件加速（IPQ6000 专用 稳定版）
# ==============================
CONFIG_PACKAGE_kmod-qca-nss-drv-wifi=y
CONFIG_PACKAGE_kmod-qca-nss-drv-igs=y
CONFIG_PACKAGE_kmod-qca-nss-drv-l2tpv2=n
CONFIG_PACKAGE_kmod-qca-nss-drv-lag-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-map-t=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pptp=n
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=n
CONFIG_PACKAGE_kmod-qca-nss-drv-nat=y
CONFIG_PACKAGE_kmod-qca-nss-macsec=n
CONFIG_NSS_DRV_SHAPER_ENABLE=y
CONFIG_NSS_DRV_PVXLAN_ENABLE=y
CONFIG_NSS_FIRMWARE_VERSION_12_2=y

# ==============================
# 内核性能优化（低延迟+高转发）
# ==============================
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=y
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE_ALWAYS=y
CONFIG_KERNEL_HUGETLBFS=y
CONFIG_KERNEL_HUGETLB_PAGE=y
CONFIG_KERNEL_NET_CLS_CGROUP=y
CONFIG_KERNEL_NETWORK_SECMARK=y
CONFIG_KERNEL_NETFILTER_NETLINK=y
CONFIG_KERNEL_IRQ_AFFINITY=y

# ==============================
# 网络加速：全锥NAT + CAKE队列
# ==============================
CONFIG_PACKAGE_iptables-mod-fullconenat=y
CONFIG_PACKAGE_kmod-ipt-fullconenat=y
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-sched-core=y

# ==============================
# LuCI 主题 仅 Argon
# ==============================
CONFIG_PACKAGE_luci-theme-aurora=n
CONFIG_PACKAGE_luci-app-aurora-config=n
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# ==============================
# LuCI 插件（精简稳定版，纯路由）
# ==============================
CONFIG_PACKAGE_luci-app-acme=n
CONFIG_PACKAGE_luci-app-ddns=n
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-samba4=n
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-app-uhttpd=n
CONFIG_PACKAGE_luci-app-frps=n
CONFIG_PACKAGE_luci-app-frpc=n
CONFIG_PACKAGE_luci-app-diskman=n
CONFIG_PACKAGE-luci-app-hd-idle=n
CONFIG_PACKAGE_luci-app-3cat=n
CONFIG_PACKAGE-luci-app-watchcat=y
CONFIG_PACKAGE_luci-proto-wireguard=n

CONFIG_PACKAGE_luci-app-banip=n
CONFIG_PACKAGE_luci-app-arpbind=n
CONFIG_PACKAGE_luci-app-usb-printer=n
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_luci-app-oaf=y
CONFIG_PACKAGE_luci-app-sqm=n
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE-luci-app-wechatpush=n
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_luci-app-smartdns=n
CONFIG_PACKAGE_luci-app-lucky=n
CONFIG_PACKAGE_luci-app-openclash=n
CONFIG_PACKAGE_luci-app-passwall2=n
CONFIG_PACKAGE_luci-app-wifischedule=n

# ==============================
# nftables 模块（纯路由无代理 极致精简）
# ==============================
CONFIG_PACKAGE_kmod-nf-nat6=n
CONFIG_PACKAGE_kmod-nft-arp=n
CONFIG_PACKAGE_kmod-nft-bridge=n
CONFIG_PACKAGE_kmod-nft-connlimit=n
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-dup-inet=n
CONFIG_PACKAGE_kmod-nft-fib=n
CONFIG_PACKAGE_kmod-nft-fullcone=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-netdev=n
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-queue=n
CONFIG_PACKAGE_kmod-nft-socket=n
CONFIG_PACKAGE_kmod-nft-tproxy=n
CONFIG_PACKAGE_kmod-nft-xfrm=n

